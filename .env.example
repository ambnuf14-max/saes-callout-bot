# Discord Configuration
DISCORD_TOKEN=your_discord_bot_token_here
DISCORD_CLIENT_ID=your_discord_application_id_here
# ID главного сервера (единственный сервер где лидеры фракций генерируют токены)
MAIN_GUILD_ID=your_main_guild_id_here
# Discord ID владельца бота (для доступа к панели мониторинга чатов)
OWNER_DISCORD_ID=your_discord_user_id_here

# VK Configuration
VK_TOKEN=your_vk_group_token_here
VK_GROUP_ID=your_vk_group_id_here

# Telegram Configuration
TELEGRAM_BOT_TOKEN=token
TELEGRAM_BOT_USERNAME=username

# Database
DATABASE_PATH=/app/data/database.sqlite

# Logging
LOG_LEVEL=info
LOG_FILE=/app/logs/bot.log

# Features
AUTO_DELETE_CHANNELS=true
CHANNEL_DELETE_DELAY=300000
