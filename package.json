{
  "name": "saes-callout-bot",
  "version": "1.0.0",
  "description": "Discord, VK & Telegram Callout System for SAES RP Server",
  "main": "dist/index.js",
  "scripts": {
    "dev": "ts-node-dev --respawn --transpile-only src/index.ts",
    "build": "tsc",
    "start": "node dist/index.js",
    "migrate": "ts-node src/database/migrations.ts",
    "docker:logs": "docker-compose logs -f --tail=1000",
    "docker:logs:all": "docker-compose logs -f --tail=all",
    "docker:up": "docker-compose up -d",
    "docker:down": "docker-compose down",
    "docker:restart": "docker-compose restart"
  },
  "keywords": [
    "discord",
    "vk",
    "telegram",
    "bot",
    "callout",
    "roleplay"
  ],
  "author": "",
  "license": "MIT",
  "dependencies": {
    "discord.js": "^14.14.1",
    "vk-io": "^4.7.0",
    "node-telegram-bot-api": "^0.66.0",
    "sqlite3": "^5.1.7",
    "dotenv": "^16.4.1",
    "winston": "^3.11.0"
  },
  "devDependencies": {
    "@types/node": "^20.11.16",
    "@types/node-telegram-bot-api": "^0.64.7",
    "typescript": "^5.3.3",
    "ts-node": "^10.9.2",
    "ts-node-dev": "^2.0.0"
  }
}
